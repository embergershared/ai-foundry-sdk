# ─── Microsoft Foundry – Environment Configuration ───────────────────────────
# Fill in your values below. Never commit real credentials to source control.

# ─── Required ─────────────────────────────────────────────────────────────────

# Foundry project endpoint.
# Format: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
# Found on the home page of your Microsoft Foundry project.
AZURE_AI_PROJECT_ENDPOINT="https://<>resource.services.ai.azure.com/api/projects/abc"

# ─── Optional ─────────────────────────────────────────────────────────────────

# Name of a specific model deployment to look up individually.
# Visible in the Foundry portal: Build > Models (first column of the Deployments table).
# Leave blank to skip the single-deployment lookup.
AZURE_AI_MODEL_DEPLOYMENT_NAME="gpt-5.4"